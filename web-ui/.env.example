# OpenAI API Key - Get one at https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your-api-key-here

# Optional: Anthropic API Key - Get one at https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional: Google API Key - Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your-google-key-here

# Optional: Custom base URL for OpenAI API (useful for using other providers)
OPENAI_API_BASE=https://api.openai.com/v1

# Optional: Organization ID for OpenAI API
OPENAI_ORGANIZATION=your-org-id-here

# Browser settings
CHROME_PATH=/usr/bin/google-chrome
CHROME_PERSISTENT_SESSION=false

# Display settings for headless environments
DISPLAY=:99
RESOLUTION=1920x1080x24
VNC_PASSWORD=your-vnc-password-here
RESOLUTION_WIDTH=1920
RESOLUTION_HEIGHT=1080

# Logging level (debug, info, warning, error, critical)
BROWSER_USE_LOGGING_LEVEL=info

# Whether to collect anonymous usage statistics
ANONYMIZED_TELEMETRY=false

# Set to false to disable anonymized telemetry
ANONYMIZED_TELEMETRY=true

# LogLevel: Set to debug to enable verbose logging, set to result to get results only. Available: result | debug | info
BROWSER_USE_LOGGING_LEVEL=info

# Chrome settings
CHROME_USER_DATA=
CHROME_DEBUGGING_PORT=9222
CHROME_DEBUGGING_HOST=localhost

# Display settings
# Format: WIDTHxHEIGHTxDEPTH
RESOLUTION=1920x1080x24
# Width in pixels
RESOLUTION_WIDTH=1920
# Height in pixels
RESOLUTION_HEIGHT=1080

# VNC settings
VNC_PASSWORD=youvncpassword